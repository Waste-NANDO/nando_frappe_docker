# Dev stack — custom app, port 3003, Compose project "erpnext" (preserves existing volumes).
ERPNEXT_VERSION=v16.5.0
# frappe/build and frappe/base image tag (not the same as ERPNEXT_VERSION)
FRAPPE_BRANCH=version-16
DB_PASSWORD=CHANGE_ME_DB_PASSWORD

COMPOSE_PROJECT_NAME=erpnext
COMPOSE_FILE_OUTPUT=nando-deployment/erpnext.yaml
TRAEFIK_ROUTER_PREFIX=erpnext
TRAEFIK_HOST_RULE='Host(`apps.internal.nandoai.com`)'

FRAPPE_SITE_NAME_HEADER=apps.internal.nandoai.com
FRAPPE_HOST_NAME=https://apps.internal.nandoai.com:3003
HTTPS_PUBLISH_PORT=3003

GCS_BUCKET=nando-it-backups
APP_NAME=nando-erp-dev

INCLUDE_CUSTOM_APP=yes
CUSTOM_APP_REPO=git@github.com:Waste-NANDO/nando-erpnext-module.git
# CUSTOM_APP_BRANCH=develop
CUSTOM_APP_NAME=nando_fulfillment
INCLUDE_HRMS=yes
# Pin to the same release tag as ERPNEXT_VERSION (version-16 branch tracks latest HRMS and can break)
HRMS_BRANCH=v16.5.0

CUSTOM_IMAGE=nando-erpnext-custom
CUSTOM_TAG=v16.5.0-custom-hrms
PULL_POLICY=never
