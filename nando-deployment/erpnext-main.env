# Main stack — ERPNext + HRMS, port 3000, Compose project "erpnext-main".
ERPNEXT_VERSION=v16.5.0
# frappe/build and frappe/base image tag (not the same as ERPNEXT_VERSION)
FRAPPE_BRANCH=version-16
DB_PASSWORD=CHANGE_ME_MAIN_DB_PASSWORD

COMPOSE_PROJECT_NAME=erpnext-main
COMPOSE_FILE_OUTPUT=nando-deployment/erpnext-main.yaml
TRAEFIK_ROUTER_PREFIX=erpnext-main
TRAEFIK_HOST_RULE='Host(`apps.internal.nandoai.com`)'

FRAPPE_SITE_NAME_HEADER=apps.internal.nandoai.com
FRAPPE_HOST_NAME=https://apps.internal.nandoai.com:3000
HTTPS_PUBLISH_PORT=3000

GCS_BUCKET=nando-it-backups
APP_NAME=nando-erp-main

INCLUDE_CUSTOM_APP=no
INCLUDE_HRMS=yes
HRMS_BRANCH=version-16

CUSTOM_IMAGE=nando-erpnext-main
CUSTOM_TAG=v16.5.0-hrms
PULL_POLICY=never
