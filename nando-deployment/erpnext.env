ERPNEXT_VERSION=v16.5.0
DB_PASSWORD=CHANGE_ME_DB_PASSWORD
FRAPPE_SITE_NAME_HEADER=apps.internal.nandoai.com
HTTPS_PUBLISH_PORT=3003
GCS_BUCKET=nando-it-backups
APP_NAME=nando-erp-next

# Optional custom app image. Fetch/build it with
# ./nando-deployment/fetch-custom-app.sh and ./nando-deployment/build-custom-image.sh
# before uncommenting these lines.
CUSTOM_APP_REPO=git@github.com:Waste-NANDO/nando-erpnext-module.git
# CUSTOM_APP_BRANCH=
CUSTOM_APP_NAME=nando_fulfillment
CUSTOM_IMAGE=nando-erpnext-custom
CUSTOM_TAG=v16.5.0-custom
PULL_POLICY=never