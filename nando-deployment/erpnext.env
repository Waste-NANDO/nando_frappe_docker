# Legacy dev env — prefer erpnext-dev.env. Kept for script compatibility.

ERPNEXT_VERSION=v16.5.0
FRAPPE_BRANCH=version-16
DB_PASSWORD=CHANGE_ME_DB_PASSWORD

COMPOSE_PROJECT_NAME=erpnext
COMPOSE_FILE_OUTPUT=nando-deployment/erpnext-dev.yaml
TRAEFIK_ROUTER_PREFIX=erpnext
TRAEFIK_HOST_RULE='Host(`apps.internal.nandoai.com`)'

FRAPPE_SITE_NAME_HEADER=apps.internal.nandoai.com
FRAPPE_HOST_NAME=https://apps.internal.nandoai.com:3003
HTTPS_PUBLISH_PORT=3003

GCS_BUCKET=nando-it-backups
APP_NAME=nando-erp-dev

INCLUDE_CUSTOM_APP=yes
CUSTOM_APP_KEYS=nando_crm,nando_fulfillment
SITE_INSTALL_APPS=nando_crm,nando_fulfillment

NANDO_CRM_REPO=https://github.com/Waste-NANDO/nando-erp-crm.git
NANDO_CRM_BRANCH=main

NANDO_FULFILLMENT_REPO=https://github.com/Waste-NANDO/nando-erpnext-module.git
NANDO_FULFILLMENT_BRANCH=main

INCLUDE_HRMS=yes
HRMS_BRANCH=v16.5.0

CUSTOM_IMAGE=nando-erpnext-custom
CUSTOM_TAG=v16.5.0-custom-crm
PULL_POLICY=never

BUILD_ASSETS_IN_IMAGE=yes
BENCH_BUILD_NODE_MEMORY_MB=6144
